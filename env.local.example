# ============================================================
# 生產工站分析系統 - 環境變數設定範本
# 複製此檔案為 .env 並填入實際值：
#   cp env.local.example .env
# ============================================================

# ── 資料庫（必填）────────────────────────────────────────────
# 支援 MySQL 8.0+ 或 TiDB
# 格式：mysql://使用者:密碼@主機:埠/資料庫名稱
DATABASE_URL=mysql://root:password@localhost:3306/production_line_db

# ── 認證（必填）──────────────────────────────────────────────
# Session Cookie 簽名金鑰，可用任意隨機字串（建議 32 字元以上）
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ── Manus OAuth（若使用 Manus 帳號登入則需要，否則可留空）──
VITE_APP_ID=
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://manus.im
OWNER_OPEN_ID=
OWNER_NAME=

# ── Manus 內建 API（選填）────────────────────────────────────
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=

# ── Ollama AI 分析（選填）────────────────────────────────────
# 若要使用 AI 優化建議功能，需填入 Ollama API Key
OLLAMA_API_KEY=

# ── 分析統計（選填）──────────────────────────────────────────
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# ── 應用程式設定（選填）──────────────────────────────────────
VITE_APP_TITLE=生產工站分析系統
VITE_APP_LOGO=
