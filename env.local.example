# ============================================================
# 生產工站分析系統 - 環境變數設定範本
# 複製此檔案為 .env 並填入實際值：
#   cp env.local.example .env
# ============================================================

# ── 資料庫（必填）────────────────────────────────────────────
# 支援 MySQL 8.0+ 或 TiDB
# 格式：mysql://使用者:密碼@主機:埠/資料庫名稱
DATABASE_URL=mysql://root:password@localhost:3306/production_line_db

# ── 認證（必填）──────────────────────────────────────────────
# Session Cookie 簽名金鑰，可用任意隨機字串（建議 32 字元以上）
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ── Manus OAuth（本地部署可全部留空，不影響帳號密碼登入）────
# 若留空，系統使用純帳號密碼登入模式，無需 Manus 平台
VITE_APP_ID=
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=
OWNER_OPEN_ID=
OWNER_NAME=

# ── Manus 內建 API（本地部署可留空）──────────────────────────
# 若留空，系統通知功能將無法使用（不影響主要功能）
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=

# ── Ollama AI 分析（選填）────────────────────────────────────
# 若要使用 AI 優化建議功能，需安裝並啟動本地 Ollama 服務
# 安裝說明：https://ollama.com/download
# 啟動後執行：ollama pull llama3.2（或其他支援的模型）
#
# OLLAMA_API_KEY：本地 Ollama 通常不需要 API Key，可填任意非空字串（如 local）
# OLLAMA_BASE_URL：Ollama 服務的 URL（預設 http://localhost:11434）
# OLLAMA_MODEL：使用的模型名稱（預設 llama3.2）
OLLAMA_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── 分析統計（選填）──────────────────────────────────────────
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# ── 應用程式設定（選填）──────────────────────────────────────
VITE_APP_TITLE=生產工站分析系統
VITE_APP_LOGO=
